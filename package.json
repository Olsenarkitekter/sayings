{
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "test": "node scripts/validate-data.mjs",
    "build:web": "expo export --platform web --output-dir dist && node scripts/fix-gh-pages-paths.mjs",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.25",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.13",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2"
  },
  "private": true
}
