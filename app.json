{
  "expo": {
    "name": "Daily Sayings",
    "slug": "daily-sayings",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f2e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olsen.dailysayings",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.olsen.dailysayings",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f2e8"
      },
      "edgeToEdgeEnabled": true,
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "description": "Daily proverbs, sayings and old phrases in English, Danish and Faroese.",
    "scheme": "dailysayings"
  }
}
