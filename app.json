{
  "expo": {
    "name": "Daily Sayings",
    "slug": "daily-sayings",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f2e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olsen.dailysayings"
    },
    "android": {
      "package": "com.olsen.dailysayings",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f2e8"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
