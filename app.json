{
  "expo": {
    "name": "Nuggets",
    "slug": "nuggets",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f2e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olsen.nuggets",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.olsen.nuggets",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f2e8"
      },
      "edgeToEdgeEnabled": true,
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "description": "Daily proverbs, sayings and old phrases in English, Danish and Faroese.",
    "scheme": "nuggets",
    "extra": {
      "eas": {
        "projectId": "617ba4cc-f442-49cd-94e9-0adb9c7270f2"
      }
    }
  }
}
